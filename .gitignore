# ────────────────────────────────────────────
# DotGhostBoard .gitignore
# ────────────────────────────────────────────

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──
venv/
.venv/
env/
.env/

# ── Environment / Secrets ──
.env
*.env
.env.local

# ── Database (local data — never commit) ──
ghost.db
ghost.db-shm
ghost.db-wal
*.sqlite
*.sqlite3

# ── Captured Media (user data) ──
data/captures/
data/pins/
data/v_logs/

# ── IDE / Editor ──
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──
*.log
logs/

# ── PyInstaller ──
*.spec
dist/
build/

# ── AppImage ──
*.AppImage
appimagetool
AppDir/

# ── pytest / Coverage ──
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── MyPy ──
.mypy_cache/

# ── Ruff / Linting ──
.ruff_cache/

# ── Generated Data & Thumbnails (v1.2.0+) ──
data/captures/
!data/captures/.gitkeep  # Keep the folder structure
data/pins/
!data/pins/.gitkeep    # Keep the folder structure
data/v_logs/
!data/v_logs/.gitkeep  # Keep the folder structure
data/thumbnails/   # S002: Video/Image thumbnails folder
!data/thumbnails/.gitkeep  # Keep the folder structure

*.snap

todo_list(*).json
roadmap(*).json

bug_fixes_v1.4.1.md